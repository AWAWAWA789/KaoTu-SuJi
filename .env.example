# ====================================================================
# 考途速记 环境变量示例 - 复制为 .env 后按需修改
# ====================================================================

# ---- 应用 ----
APP_PORT=3000
APP_URL=http://localhost:5173
NODE_ENV=development

# ---- LLM Provider ----
# 默认 mock（开发零配置可跑）；生产请切换为 deepseek
LLM_PROVIDER=mock
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_MODEL=kimi-k2.6

# ---- 数据库 ----
# 协议段决定 dialect：file:./data/app.db → SQLite；mysql://... → MySQL 8
DATABASE_URL=file:./data/app.db

# ---- Redis（可选，不存在则降级为进程内 Map）----
# REDIS_URL=redis://localhost:6379

# ---- SMTP（可选，不存在时验证码打日志）----
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=

# ---- JWT ----
JWT_SECRET=please-change-me-in-production-at-least-32-chars-long
JWT_EXPIRES_IN=7d

# ---- 配额（默认值，可覆盖）----
QUOTA_GENERATE_MONTHLY_FREE=20
QUOTA_PDF_DAILY_FREE=10
QUOTA_CONFIG_CHAT_DAILY=60

# ---- PDF Worker ----
PDF_WORKER_CONCURRENCY=1
